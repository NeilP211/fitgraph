# Copy this file to .env and fill in your values.
# Environment variables are prefixed with FITGRAPH_.

# PostgreSQL connection string (pgvector-enabled instance)
FITGRAPH_DATABASE_URL=postgresql+psycopg://fitgraph:fitgraph@localhost:5432/fitgraph

# Redis connection string
FITGRAPH_REDIS_URL=redis://localhost:6379/0

# Set to true to log runs to Weights & Biases
FITGRAPH_WANDB_ENABLED=false

# Kaggle credentials — read directly by the kaggle library from the shell environment.
# Set KAGGLE_API_TOKEN (or place ~/.kaggle/kaggle.json) before running data-download commands.
# KAGGLE_API_TOKEN=<your_token_here>
